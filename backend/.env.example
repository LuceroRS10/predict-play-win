# ============================================================
# PREDICT PLAY WIN — Environment Configuration
# ============================================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/ppw?schema=public

# JWT Security
# IMPORTANT: Generate a strong secret for production (min 32 chars)
# Example: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Football API (api-football.com)
API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ============================================================
# SECURITY NOTES:
# - Never commit .env to git
# - Use different secrets for dev/staging/production
# - JWT_SECRET must be unique and random (64+ chars recommended)
# - Set NODE_ENV=production in production
# - Set FRONTEND_URL to your actual domain in production
# ============================================================
